{
  "name": "ravenna/llms-generator",
  "type": "statamic-addon",
  "license": "MIT",
  "description": "LLMS.txt generator for Statamic",
  "autoload": {
    "psr-4": {
      "Ravenna\\LlmsGenerator\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ravenna\\LlmsGenerator\\Tests\\": "tests"
    }
  },
  "require": {
    "php": ">=8.2",
    "statamic/cms": "^5.0|^6.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0"
  },
  "config": {
    "allow-plugins": {
      "pixelfear/composer-dist-plugin": true
    }
  },
  "extra": {
    "statamic": {
      "name": "LLMs Generator",
      "description": "LLMS.txt generator for Statamic",
      "namespace": "Ravenna\\LlmsGenerator"
    },
    "laravel": {
      "providers": [
        "Ravenna\\LlmsGenerator\\ServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
